!third_party/.gitkeep

# --- assets (heavy MJCF / meshes pulled by scripts/setup_assets.sh) ---
assets/**
!assets/.gitkeep
!assets/README.md

# --- IDE / OS ---
.idea/
.vscode/
*.swp
.DS_Store

# --- container HOME droppings (HOME=/workspace/otus_rl_project inside container) ---
