motions/**
!motions/.gitkeep
wandb/
*.pt
*.pth
*.ckpt
*.onnx
*.tar.gz

# --- MuJoCo / rendering ---
*.mp4
*.gif
MUJOCO_LOG.TXT

# --- third_party (cloned repos) ---
